{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/proxy.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/app.js",
      "destination": "/assets/proxyv-client.js",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|styles.css|404.html).*)",
      "destination": "/index.html"
    }
  ]
}
